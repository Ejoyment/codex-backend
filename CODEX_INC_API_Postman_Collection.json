  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "console.log('Starting request to ' + pm.request.url);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Store authentication token from login response",
          "if (pm.response.code === 200) {",
          "    var jsonData = pm.response.json();",
          "    if (jsonData.token) {",
          "        pm.collectionVariables.set('auth_token', jsonData.token);",
          "        console.log('Auth token stored: ' + jsonData.token.substring(0, 20) + '...');",
          "    }",
          "    if (jsonData.session && jsonData.session.id) {",
          "        pm.collectionVariables.set('ai_session_id', jsonData.session.id);",
          "        console.log('AI session ID stored: ' + jsonData.session.id);",
          "    }",
          "}"
        ]
      }
    }
  ],
